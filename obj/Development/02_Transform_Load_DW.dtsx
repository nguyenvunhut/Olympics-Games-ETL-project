                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT
    g.id AS Original_ID,
    g.games_name AS Games_Name,
    g.games_year AS Year,
    g.season AS Season,
    c.city_name AS City_Name
FROM dbo.Stage_Games g
-- LEFT JOIN để vẫn lấy được Games dù chưa xác định City
LEFT JOIN dbo.Stage_Games_City gc ON g.id = gc.games_id
LEFT JOIN dbo.Stage_City c ON gc.city_id = c.id
WHERE g.id IS NOT NULL</property>
