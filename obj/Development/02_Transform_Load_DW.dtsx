            <component
              refId="Package\DFT - Fact_Olympic_Results\Source - Get Fact Data"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
              description="OLE DB Source"
              name="Source - Get Fact Data"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">/* QUERY ĐÃ ĐƯỢC TỐI ƯU ĐỂ KHỬ TRÙNG LẶP (DEDUPLICATION)
   Xử lý 2 vấn đề:
   1. Một VĐV tham gia 1 sự kiện nhưng có nhiều dòng kết quả -&gt; Lọc lấy 1 dòng tốt nhất.
   2. Một VĐV có nhiều quốc tịch -&gt; Lọc lấy 1 quốc tịch.
*/

WITH 
-- 1. Làm sạch bảng Person_Region (Chỉ lấy 1 vùng cho mỗi người)
Cleaned_Person_Region AS (
    SELECT 
        person_id, 
        region_id,
        -- Đánh số 1 cho dòng có region_id lớn nhất (hoặc logic khác tùy chọn)
        ROW_NUMBER() OVER(PARTITION BY person_id ORDER BY region_id DESC) as rn
    FROM dbo.Stage_Person_Region
),

-- 2. Làm sạch bảng Competitor_Event (Chỉ lấy 1 kết quả cho mỗi lần thi đấu)
Cleaned_Competitor_Event AS (
    SELECT 
        competitor_id, 
        event_id, 
        medal_id,
        -- Ưu tiên giữ dòng có Huy chương (medal_id lớn/khác null)
        -- Nếu không thì giữ dòng có ID lớn nhất (giả định là cập nhật mới nhất)
        ROW_NUMBER() OVER(PARTITION BY competitor_id, event_id ORDER BY medal_id DESC) as rn
    FROM dbo.Stage_Competitor_Event
)

-- 3. Truy vấn chính (Main Query) kết nối các bảng đã làm sạch
SELECT 
    p.id            AS Source_Athlete_ID,
    g.id            AS Source_Game_ID,
    e.id            AS Source_Event_ID,
    nr.id           AS Source_NOC_ID,
    m.id            AS Source_Medal_ID,
    
    m.medal_name    AS Source_Medal_Name,
    nr.noc          AS Source_NOC_Code,
    gc.age          AS Source_Age
    
FROM Cleaned_Competitor_Event ce -- Dùng bảng đã làm sạch thay vì bảng gốc
INNER JOIN dbo.Stage_Games_Competitor gc ON ce.competitor_id = gc.id
INNER JOIN dbo.Stage_Person p            ON gc.person_id = p.id
INNER JOIN dbo.Stage_Games g             ON gc.games_id = g.id
INNER JOIN dbo.Stage_Event e             ON ce.event_id = e.id

-- Join lấy Medal (dùng bảng gốc vì bảng này danh mục, không trùng)
LEFT JOIN dbo.Stage_Medal m              ON ce.medal_id = m.id

-- Join lấy Region đã làm sạch
LEFT JOIN Cleaned_Person_Region pr       ON p.id = pr.person_id AND pr.rn = 1

-- Join lấy thông tin NOC
LEFT JOIN dbo.Stage_NOC_Region nr        ON pr.region_id = nr.id

WHERE ce.rn = 1; -- QUAN TRỌNG: Chỉ lấy những dòng được đánh số 1 (Duy nhất)</property>
                <property
                  dataType="System.String"
                  description="The variable that contains the SQL command to be executed."
                  name="SqlCommandVariable"></property>
                <property
                  dataType="System.Int32"
                  description="Specifies the column code page to use when code page information is unavailable from the data source."
                  name="DefaultCodePage">1252</property>
                <property
                  dataType="System.Boolean"
                  description="Forces the use of the DefaultCodePage property value when describing character data."
                  name="AlwaysUseDefaultCodePage">false</property>
                <property
                  dataType="System.Int32"
                  description="Specifies the mode used to access the database."
                  name="AccessMode"
                  typeConverter="AccessMode">2</property>
                <property
                  dataType="System.String"
                  description="The mappings between the parameters in the SQL command and variables."
                  name="ParameterMapping"></property>
              </properties>
              <connections>
                <connection
                  refId="Package\DFT - Fact_Olympic_Results\Source - Get Fact Data.Connections[OleDbConnection]"
                  connectionManagerID="{D4274A5C-0D03-4901-AD9B-E3A1A85F7527}:external"
                  connectionManagerRefId="Project.ConnectionManagers[Conn_Dest_Staging]"
                  description="The OLE DB runtime connection used to access the database."
                  name="OleDbConnection" />
              </connections>
              <outputs>
                <output
                  refId="Package\DFT - Fact_Olympic_Results\Source - Get Fact Data.Outputs[OLE DB Source Output]"
                  name="OLE DB Source Output">
                  <outputColumns>
                    <outputColumn
                      refId="Package\DFT - Fact_Olympic_Results\Source - Get Fact Data.Outputs[OLE DB Source Output].Columns[Source_Athlete_ID]"
                      dataType="i4"
                      errorOrTruncationOperation="Conversion"
                      errorRowDisposition="FailComponent"
                      externalMetadataColumnId="Package\DFT - Fact_Olympic_Results\Source - Get Fact Data.Outputs[OLE DB Source Output].ExternalColumns[Source_Athlete_ID]"
                      lineageId="Package\DFT - Fact_Olympic_Results\Source - Get Fact Data.Outputs[OLE DB Source Output].Columns[Source_Athlete_ID]"
                      name="Source_Athlete_ID"
                      truncationRowDisposition="FailComponent" />
                    <outputColumn
                      refId="Package\DFT - Fact_Olympic_Results\Source - Get Fact Data.Outputs[OLE DB Source Output].Columns[Source_Game_ID]"
                      dataType="i4"
                      errorOrTruncationOperation="Conversion"
                      errorRowDisposition="FailComponent"
                      externalMetadataColumnId="Package\DFT - Fact_Olympic_Results\Source - Get Fact Data.Outputs[OLE DB Source Output].ExternalColumns[Source_Game_ID]"
                      lineageId="Package\DFT - Fact_Olympic_Results\Source - Get Fact Data.Outputs[OLE DB Source Output].Columns[Source_Game_ID]"
                      name="Source_Game_ID"
                      truncationRowDisposition="FailComponent" />
                    <outputColumn
